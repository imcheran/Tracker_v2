rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Helper Functions ──────────────────────────────────────────────

    // Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Check if user is the owner of a document
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Check if user is in the couple's members array
    function isCouplesMember(coupleMembers) {
      return request.auth.uid in coupleMembers;
    }

    // ─── User Documents ───────────────────────────────────────────────

    // Personal user documents - only the user can read/write their own
    match /users/{uid} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    // ─── Partner Invite Codes ──────────────────────────────────────────

    // Temporary invite codes - only sender can create, anyone can read to verify
    match /partnerInvites/{code} {
      // Create: Only authenticated users can create
      allow create: if isAuth();
      
      // Read: Anyone can read to validate
      allow read: if isAuth();
      
      // Update: Only the sender or during transaction
      allow update: if isAuth() && (
        request.auth.uid == resource.data.senderUid ||
        // Allow transactions to mark as used
        request.resource.data.used == true
      );
      
      // Delete: Not allowed (keep history)
      allow delete: false;
    }

    // ─── Couple Space ──────────────────────────────────────────────────

    // Couple documents - only linked partners can access
    match /couples/{coupleId} {
      // Couple document: only members can read/write
      allow read: if isAuth() && isCouplesMember(resource.data.members);
      allow write: if isAuth() && isCouplesMember(resource.data.members);

      // Couple subcollections (habits, photos, journal, etc)
      match /{subcollection}/{document=**} {
        allow read, write: if isAuth() && isCouplesMember(get(/databases/$(database)/documents/couples/$(coupleId)).data.members);
      }
    }

    // ─── Deny Everything Else ──────────────────────────────────────────

    match /{document=**} {
      allow read, write: false;
    }
  }
}
